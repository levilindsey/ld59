# Godot 4+ specific ignores
.godot/
/android/

# Executables
*.exe
*.out
*.app

~*.dll
~*.TMP

# OS metadata
.DS_Store
Thumbs.db

# Logs
*.log

*DO_NOT_SUBMIT*

build/*

# GDExtension build artifacts.
ld59extension/bin/
ld59extension/.scons_cache/
ld59extension/.sconsign.dblite
ld59extension/**/*.pyc
ld59extension/**/__pycache__/
ld59extension/**/*.o
ld59extension/**/*.os
ld59extension/**/*.obj

# Allow committed addon binaries (only the runtime .dll/.wasm; MSVC
# import libraries and export tables are build-only and stay out).
!addons/ld59extension/bin/*.dll
!addons/ld59extension/bin/*.wasm
# MSVC build byproducts that install places alongside the .dll —
# committed dll stays, these never do.
addons/ld59extension/bin/*.exp
addons/ld59extension/bin/*.lib
addons/ld59extension/bin/*.pdb
# Godot's hot-reload leaves tilde-prefixed copies of the live dll.
addons/ld59extension/bin/~*.dll
