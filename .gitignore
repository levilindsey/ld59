# Godot 4+ specific ignores
.godot/
/android/

# Executables
*.exe
*.out
*.app

~*.dll
~*.TMP

# OS metadata
.DS_Store
Thumbs.db

# Logs
*.log

*DO_NOT_SUBMIT*

build/*

# Web server npm deps (installed via `npm install` in web/ before
# running the static server; recreated per-machine).
web/node_modules/

# GDExtension build artifacts.
kbterrain/bin/
kbterrain/.scons_cache/
kbterrain/.sconsign.dblite
kbterrain/**/*.pyc
kbterrain/**/__pycache__/
kbterrain/**/*.o
kbterrain/**/*.os
kbterrain/**/*.obj

# Allow committed addon binaries (only the runtime .dll/.wasm; MSVC
# import libraries and export tables are build-only and stay out).
!addons/kbterrain/bin/*.dll
!addons/kbterrain/bin/*.wasm
# MSVC build byproducts that install places alongside the .dll —
# committed dll stays, these never do.
addons/kbterrain/bin/*.exp
addons/kbterrain/bin/*.lib
addons/kbterrain/bin/*.pdb
# Godot's hot-reload leaves tilde-prefixed copies of the live dll.
addons/kbterrain/bin/~*.dll
